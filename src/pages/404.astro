---
import { getCollection } from "astro:content";
import DocLayout from "@/layouts/DocLayout.astro";
import { buildNavTree } from "@/lib/nav";
import { ArrowLeft, Bug } from "lucide-react";

const allDocs = await getCollection("docs");
const nav = buildNavTree(allDocs);
---

<DocLayout title="Page not found" showTitle={false} noIndex nav={nav} currentHref="">
  <div class="flex flex-col items-center justify-center text-center py-20 gap-8">
    <Bug size={192} />
    <div class="space-y-3">
      <p class="text-7xl font-black tracking-tight text-neutral-900 dark:text-neutral-100 leading-none">404</p>
      <h1 class="text-2xl font-semibold text-neutral-900 dark:text-neutral-100">Something bugged out</h1>
      <p class="text-neutral-500 dark:text-neutral-400">This page must have crawled off somewhere.</p>
    </div>
    <a href="/" class="mdx-a inline-flex items-center gap-1.5 font-medium">
      <ArrowLeft size={14} class="translate-y-px" />Take me home
    </a>
  </div>
</DocLayout>
